---
// Walkthrough section for sw_033. Loads pre-built data and wires interactive
// state on the client (vanilla JS). External text payloads (full snapshots and
// retrieved contexts) are fetched on demand from {baseUrl}sw033/.
import data from "../data/sw033.json";

const baseUrl = import.meta.env.BASE_URL;
const dataJson = JSON.stringify({ ...data, baseUrl });
const { episode, sessions, systems, systemLabels, taskOrder, grid } = data;

// Session-kind helpers for static markup
const probeBefore = episode.probe_before_idx;
const probeAfter = episode.probe_after_idx;
---

<section class="walkthrough" aria-labelledby="wt-title">
  <header class="wt-head">
    <h2 id="wt-title">
      <span class="wt-eyebrow">Walkthrough</span>
      Episode <code>sw_033</code> — software project
    </h2>
    <p class="wt-meta">
      {episode.total_sessions} sessions
      ({episode.evidence_sessions} evidence, {episode.filler_sessions} filler) ·
      ~{Math.round(episode.total_tokens / 1000)}K tokens · cascade root:
      <code>{episode.root}</code>
    </p>
  </header>

  <!-- Result grid -->
  <div class="card">
    <h3 class="card-title">Result grid <span class="card-sub">(6 tasks × 7 systems, after-questions)</span></h3>
    <div class="grid-wrap" role="region" aria-label="Result grid">
      <table class="result-grid">
        <thead>
          <tr>
            <th></th>
            {systems.map((s) => (
              <th class={`sys-col${systemLabels[s].featured ? " featured" : ""}`}>
                <span class="sys-name">{systemLabels[s].name}</span>
                {systemLabels[s].featured && (
                  <span class="sys-llm">{systemLabels[s].internalLLM}</span>
                )}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {taskOrder.map((tag) => (
            <tr>
              <th scope="row" class="task-row-label">{tag}</th>
              {systems.map((s) => {
                const cell = grid[tag][s];
                return (
                  <td>
                    <button
                      class={`gcell ${cell?.u_pass ? "pass" : "fail"}`}
                      data-task={tag}
                      data-system={s}
                      aria-label={`${tag} ${systemLabels[s].name} ${cell?.u_pass ? "pass" : "fail"}`}
                    >{cell?.u_pass ? "✓" : "✗"}</button>
                  </td>
                );
              })}
            </tr>
          ))}
          <tr class="totals-row">
            <th scope="row">Total</th>
            {systems.map((s) => {
              const n = taskOrder.filter((t) => grid[t][s]?.u_pass).length;
              return <td class={`total${systemLabels[s].featured ? " featured" : ""}`}>{n}/{taskOrder.length}</td>;
            })}
          </tr>
        </tbody>
      </table>
    </div>
    <p class="hint">Click a cell to inspect the agent's actual answer for that task–system pair.</p>
  </div>

  <!-- System tabs -->
  <div class="card system-card">
    <h3 class="card-title">Inspect a system</h3>
    <div class="system-tabs" role="tablist">
      {systems.map((s) => (
        <button
          class={`sys-tab${systemLabels[s].featured ? " featured" : ""}`}
          role="tab"
          data-system={s}
          aria-selected={s === "md_file" ? "true" : "false"}
        >
          {systemLabels[s].name}
          {systemLabels[s].featured && (
            <span class="tab-llm">{systemLabels[s].internalLLM}</span>
          )}
        </button>
      ))}
    </div>

    <!-- Timeline + Sparkline -->
    <div class="timeline">
      <div class="series-key">
        <span><span class="line-key size"></span>memory size</span>
        <span><span class="line-key gold"></span>gold-fact %</span>
      </div>

      <div class="tl-graph" id="tl-graph" aria-hidden="true">
        <!-- SVG injected by JS -->
      </div>

      <div class="tl-row" role="tablist" aria-label="Sessions">
        {sessions.map((sess) => {
          // probe sessions are still real filler sessions data-wise; treat as such visually
          const baseKind =
            sess.kind === "evidence" ? "evidence" : "filler";
          return (
            <button
              class={`tl-cell ${baseKind}`}
              data-session={sess.idx}
              role="tab"
              aria-selected={sess.idx === 9 ? "true" : "false"}
              title={`Session ${sess.idx} · ${sess.timestamp ?? ""}`}
            >
              <span class="tl-idx">{sess.idx}</span>
            </button>
          );
        })}
      </div>

      <!-- Probe events: evaluation moments, NOT sessions. Positioned below the session row.
           - probe before: between session 13 and 14 (asked after session 13, before evidence at 14)
           - probe after:  to the right of session 16 (asked at the end of the episode) -->
      <div class="tl-probe-row" aria-label="Probe events">
        <button
          class="probe-marker probe-before"
          data-probe="before"
          title="Probe (before-questions), asked after session 13"
          style="left: 80.555%;"
        >
          <span class="probe-arrow" aria-hidden="true">▲</span>
          <span class="probe-label">probe before</span>
        </button>
        <button
          class="probe-marker probe-after"
          data-probe="after"
          title="Probe (after-questions), asked after session 16"
          style="left: 97.222%;"
        >
          <span class="probe-arrow" aria-hidden="true">▲</span>
          <span class="probe-label">probe after</span>
        </button>
      </div>

      <div class="tl-legend">
        <span><span class="dot filler"></span>filler session</span>
        <span><span class="dot evidence"></span>evidence session</span>
        <span><span class="probe-mini">▲</span>probe (evaluation event)</span>
      </div>
    </div>

    <!-- Detail pane -->
    <div class="detail-pane" id="detail-pane">
      <!-- Rendered by JS -->
    </div>
  </div>
</section>

<script id="sw033-data" type="application/json" set:html={dataJson}></script>

<script is:inline>
  (() => {
    const DATA = JSON.parse(document.getElementById("sw033-data").textContent);
    const { episode, sessions, systems, systemLabels, snapshots, series, grid, taskOrder, results, baseUrl } = DATA;
    const BASE = baseUrl || "/";

    const state = {
      session: 9,
      system: "md_file",
      diffMode: "diff", // 'diff' | 'full'
      expandedTask: null, // string | null
      probeMode: null, // null | 'before' | 'after'
    };

    // ─── Sparkline (SVG) ─────────────────────────────────────────────
    const TL_W = 900;
    const TL_H = 130;
    const TL_PAD = { top: 28, right: 50, bottom: 22, left: 50 };

    function drawSparkline() {
      const s = series[state.system];
      const N = s.size.length;
      const maxY = Math.max(...s.size, 1);
      // gold-fact as ratio of total snapshot chars (0..1)
      const ratio = s.size.map((sz, i) => (sz > 0 ? s.gold[i] / sz : 0));
      const x = (i) =>
        TL_PAD.left +
        (i * (TL_W - TL_PAD.left - TL_PAD.right)) / (N - 1);
      const ySize = (v) =>
        TL_PAD.top +
        (1 - v / maxY) * (TL_H - TL_PAD.top - TL_PAD.bottom);
      const yRatio = (v) =>
        TL_PAD.top +
        (1 - v) * (TL_H - TL_PAD.top - TL_PAD.bottom);
      const pathFor = (arr, yFn) =>
        arr
          .map((v, i) => `${i === 0 ? "M" : "L"}${x(i).toFixed(1)},${yFn(v).toFixed(1)}`)
          .join(" ");

      const container = document.getElementById("tl-graph");
      const sizePath = pathFor(s.size, ySize);
      const goldPath = pathFor(ratio, yRatio);
      const sel = state.session;

      const fmt = (v) =>
        v >= 1000 ? `${(v / 1000).toFixed(1)}K` : String(Math.round(v));
      const yTicks = [0, 0.5, 1];

      const STROKE_SIZE = "#2563eb";
      const STROKE_GOLD = "#d97706";
      const C_MUTED = "#5b5b5b";
      const C_BORDER = "#e5e3dc";

      container.innerHTML = `
        <svg viewBox="0 0 ${TL_W} ${TL_H}" preserveAspectRatio="none" width="100%" height="${TL_H}" style="display:block">
          ${yTicks
            .map((t) => {
              const yv = ySize(maxY * t);
              return (
                `<line x1="${TL_PAD.left}" x2="${TL_W - TL_PAD.right}" y1="${yv}" y2="${yv}" stroke="${C_BORDER}" stroke-width="1" stroke-dasharray="2 3" vector-effect="non-scaling-stroke"/>` +
                // left axis: chars
                `<text x="${TL_PAD.left - 6}" y="${yv + 3}" fill="${STROKE_SIZE}" font-size="10" text-anchor="end">${fmt(maxY * t)}</text>` +
                // right axis: ratio %
                `<text x="${TL_W - TL_PAD.right + 6}" y="${yv + 3}" fill="${STROKE_GOLD}" font-size="10" text-anchor="start">${Math.round(t * 100)}%</text>`
              );
            })
            .join("")}
          <text x="${TL_PAD.left - 6}" y="14" fill="${STROKE_SIZE}" font-size="10" text-anchor="end">chars</text>
          <text x="${TL_W - TL_PAD.right + 6}" y="14" fill="${STROKE_GOLD}" font-size="10" text-anchor="start">gold %</text>
          <path d="${sizePath}" fill="none" stroke="${STROKE_SIZE}" stroke-width="1.8" vector-effect="non-scaling-stroke" stroke-linejoin="round"/>
          <path d="${goldPath}" fill="none" stroke="${STROKE_GOLD}" stroke-width="1.8" vector-effect="non-scaling-stroke" stroke-linejoin="round"/>
          ${sel !== null
            ? `<line x1="${x(sel).toFixed(1)}" x2="${x(sel).toFixed(1)}" y1="${TL_PAD.top}" y2="${TL_H - TL_PAD.bottom}" stroke="#aaa" stroke-width="1" stroke-dasharray="2 2" vector-effect="non-scaling-stroke"/>` +
              `<circle cx="${x(sel).toFixed(1)}" cy="${ySize(s.size[sel]).toFixed(1)}" r="4" fill="${STROKE_SIZE}" stroke="#fff" stroke-width="1.5"/>` +
              `<circle cx="${x(sel).toFixed(1)}" cy="${yRatio(ratio[sel]).toFixed(1)}" r="4" fill="${STROKE_GOLD}" stroke="#fff" stroke-width="1.5"/>`
            : ""}
        </svg>
      `;
    }

    // ─── Timeline cell + probe marker highlight ───────────────────────
    function syncTimeline() {
      document.querySelectorAll(".tl-cell").forEach((el) => {
        const idx = +el.dataset.session;
        const isActive = !state.probeMode && idx === state.session;
        el.setAttribute("aria-selected", isActive ? "true" : "false");
        el.classList.toggle("active", isActive);
      });
      document.querySelectorAll(".probe-marker").forEach((el) => {
        const which = el.dataset.probe;
        el.classList.toggle("active", state.probeMode === which);
      });
    }

    // ─── System tabs highlight ───────────────────────────────────────
    function syncTabs() {
      document.querySelectorAll(".sys-tab").forEach((el) => {
        const sys = el.dataset.system;
        el.setAttribute("aria-selected", sys === state.system ? "true" : "false");
        el.classList.toggle("active", sys === state.system);
      });
    }

    // ─── Detail pane ─────────────────────────────────────────────────
    function escapeHtml(s) {
      return (s ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;");
    }

    // user → blue, assistant → gray
    const USER_AVATAR_SVG =
      '<svg viewBox="0 0 24 24" width="18" height="18" style="display:block" aria-hidden="true">' +
      '<circle cx="12" cy="8" r="4" fill="#d6e9fb" stroke="#185fa5" stroke-width="0.8"/>' +
      '<path d="M4 22 C4 16, 8 14, 12 14 C16 14, 20 16, 20 22" fill="#d6e9fb" stroke="#185fa5" stroke-width="0.8" stroke-linecap="round"/>' +
      "</svg>";
    const BOT_AVATAR_SVG =
      '<svg viewBox="0 0 24 24" width="18" height="18" style="display:block" aria-hidden="true">' +
      '<rect x="4" y="8" width="16" height="12" rx="2" fill="#e6e6e2" stroke="#888" stroke-width="0.8"/>' +
      '<line x1="12" y1="4" x2="12" y2="8" stroke="#888" stroke-width="0.8" stroke-linecap="round"/>' +
      '<circle cx="12" cy="3" r="1.2" fill="#e6e6e2" stroke="#888" stroke-width="0.8"/>' +
      '<circle cx="9" cy="13" r="1.2" fill="#888"/>' +
      '<circle cx="15" cy="13" r="1.2" fill="#888"/>' +
      '<line x1="9" y1="17" x2="15" y2="17" stroke="#888" stroke-width="0.8" stroke-linecap="round"/>' +
      "</svg>";

    function renderConversation(turns) {
      return turns
        .map((t) => {
          const avatar = t.role === "user" ? USER_AVATAR_SVG : BOT_AVATAR_SVG;
          const roleLabel = t.role === "user" ? "User" : "Assistant";
          return (
            `<div class="turn turn-${t.role}">` +
            `<div class="avatar">${avatar}</div>` +
            `<div class="msg">` +
            `<div class="role">${roleLabel}</div>` +
            `<div class="bubble">${escapeHtml(t.content)}</div>` +
            `</div>` +
            `</div>`
          );
        })
        .join("");
    }

    function renderGoldFacts(facts) {
      if (!facts.length) return "";
      return `
        <div class="gold-facts">
          <h5>Gold facts introduced</h5>
          <ul>${facts
            .map((f) => {
              const chips = tagChips(f.tags);
              const val = Array.isArray(f.value) ? f.value.join(", ") : f.value;
              return `<li>${chips}<code>${escapeHtml(f.entity)}</code> = <strong>${escapeHtml(val)}</strong></li>`;
            })
            .join("")}</ul>
        </div>
      `;
    }

    function tagChips(tags) {
      if (!tags || tags.length === 0) return "";
      return tags
        .map((t) => `<span class="ln-chip chip-${t}">${t}</span>`)
        .join("");
    }
    function renderDiff(added, removed) {
      const a = added || [];
      const r = removed || [];
      if (a.length === 0 && r.length === 0)
        return `<div class="snap-empty">No diff at this session.</div>`;
      const lineHtml = (sign, item) => {
        // item may be a string (older format) or {text, tags}
        const text = typeof item === "string" ? item : item.text ?? "";
        const tags = typeof item === "string" ? [] : item.tags ?? [];
        const chips = tagChips(tags);
        const safe = escapeHtml(text) || "&nbsp;";
        return `<span class="ln ${sign === "+" ? "added" : "removed"}">${chips}${sign} ${safe}</span>`;
      };
      const aBlock = a.map((i) => lineHtml("+", i)).join("\n");
      const rBlock = r.map((i) => lineHtml("−", i)).join("\n");
      const sep = aBlock && rBlock ? "\n" : "";
      return `<pre class="snap-block diff">${aBlock}${sep}${rBlock}</pre>`;
    }

    async function fetchSnapshot(sys, idx) {
      const r = await fetch(`${BASE}sw033/snap/${sys}/${idx}.txt`);
      if (!r.ok) throw new Error("snapshot fetch failed");
      return await r.text();
    }

    async function renderFullSnapshot(target, sys, idx, addedSet) {
      target.innerHTML = `<div class="snap-loading">Loading…</div>`;
      try {
        const txt = await fetchSnapshot(sys, idx);
        // For performance with bm25/dense (large), render in chunks of N lines on scroll.
        const lines = txt.split("\n");
        const CHUNK = 200;
        let rendered = 0;
        const pre = document.createElement("pre");
        pre.className = "snap-block full";
        target.innerHTML = "";
        target.appendChild(pre);

        const renderChunk = () => {
          const end = Math.min(rendered + CHUNK, lines.length);
          const frag = document.createDocumentFragment();
          for (let i = rendered; i < end; i++) {
            const ln = lines[i];
            const span = document.createElement("span");
            span.className = "ln" + (addedSet.has(ln) ? " added" : "");
            span.textContent = ln || " ";
            frag.appendChild(span);
            if (i < end - 1) frag.appendChild(document.createTextNode("\n"));
          }
          pre.appendChild(frag);
          rendered = end;
          if (rendered < lines.length) {
            // Continue on idle
            requestIdleCallback
              ? requestIdleCallback(renderChunk)
              : setTimeout(renderChunk, 16);
          } else {
            const meta = document.createElement("div");
            meta.className = "snap-meta";
            meta.textContent = `${lines.length.toLocaleString()} lines · ${txt.length.toLocaleString()} chars`;
            target.appendChild(meta);
          }
        };
        renderChunk();
      } catch (e) {
        target.innerHTML = `<div class="snap-error">Failed to load snapshot.</div>`;
      }
    }

    function renderSnapshotPane() {
      const sys = state.system;
      const idx = state.session;
      const diff = snapshots[sys].diff[idx];
      const added = diff?.added ?? [];
      const removed = diff?.removed ?? [];
      const sysLabel = systemLabels[sys];

      const header = `
        <div class="snap-head">
          <h4>Memory snapshot
            <span class="snap-sub">${sysLabel.name}</span>
          </h4>
          <div class="snap-controls">
            <button class="seg ${state.diffMode === "diff" ? "active" : ""}" data-diff-mode="diff">Diff-only</button>
            <button class="seg ${state.diffMode === "full" ? "active" : ""}" data-diff-mode="full">Full</button>
          </div>
        </div>
        <div class="snap-summary">
          <span class="badge added-badge">+${added.length} lines</span>
          ${removed.length ? `<span class="badge removed-badge">−${removed.length} lines</span>` : ""}
          <span class="badge size-badge">${(series[sys].size[idx] ?? 0).toLocaleString()} chars total</span>
        </div>
      `;

      const body =
        state.diffMode === "diff"
          ? `<div class="snap-body">${renderDiff(added, removed)}</div>`
          : `<div class="snap-body" id="snap-body-full"></div>`;

      return header + body;
    }

    async function hookFullSnapshot() {
      if (state.diffMode !== "full") return;
      const target = document.getElementById("snap-body-full");
      if (!target) return;
      const sys = state.system;
      const idx = state.session;
      const addedSet = new Set(snapshots[sys].diff[idx]?.added ?? []);
      await renderFullSnapshot(target, sys, idx, addedSet);
    }

    function renderSessionPane() {
      const sess = sessions[state.session];
      const evtLabel =
        sess.kind === "evidence"
          ? `<span class="kind-pill evidence">evidence</span>`
          : sess.kind === "filler"
            ? `<span class="kind-pill filler">filler</span>`
            : "";

      return `
        <div class="sess-pane">
          <div class="sess-head">
            <h4>Session ${sess.idx} ${evtLabel}</h4>
            <div class="sess-ts">${escapeHtml(sess.timestamp ?? "")}</div>
          </div>
          ${renderGoldFacts(sess.gold_facts)}
          <div class="sess-conv">${renderConversation(sess.conversation)}</div>
        </div>
      `;
    }

    function renderQATrace() {
      const sys = state.system;
      const phase = state.probeMode; // 'before' | 'after'
      const probeIdx = phase === "before" ? episode.probe_before_idx : episode.probe_after_idx;
      const probeTs = phase === "before" ? episode.probe_before_timestamp : episode.probe_after_timestamp;
      const items = results[sys][phase];
      const tasks = items;

      // Judge files use different task_type strings between before/after
      // (e.g. "Exact" vs "Exact (exact recall)", "Deletion" vs "Deletion (before delete)").
      // Map by prefix so both forms collapse to the same short tag.
      const toTag = (t) => {
        if (!t) return "?";
        if (t.startsWith("Cascade-D")) return "Cas";
        if (t.startsWith("Cascade-U")) return "Abs";
        if (t.startsWith("Deletion")) return "Del";
        if (t.startsWith("Exact")) return "ER";
        if (t.startsWith("Multi-hop")) return "Agg";
        if (t.startsWith("Multiple-update")) return "Tr";
        return t;
      };

      // For "before", drop ER per user preference
      const filtered = phase === "before" ? tasks.filter((t) => toTag(t.task_type) !== "ER") : tasks;

      const stagesHtml = (fa) => {
        if (!fa) return "";
        const stages = [
          ["Encoded", fa.encoded],
          ["Maintained", fa.maintained],
          ["Retrieved", fa.retrieved],
          ["Answered", fa.answered],
        ];
        const firstFalse = stages.findIndex(([, v]) => !v);
        const row =
          `<div class="qa-line qa-stages">` +
          stages
            .map(([name, ok], i) => {
              const failHere = firstFalse !== -1 && i === firstFalse;
              const dim = firstFalse !== -1 && i > firstFalse;
              const cls = failHere ? "stage fail" : ok ? "stage pass" : dim ? "stage dim" : "stage pass";
              const mark = ok ? "✓" : "✗";
              const sep = i < stages.length - 1 ? `<span class="stage-arrow">→</span>` : "";
              return `<span class="${cls}">${name} ${mark}</span>${sep}`;
            })
            .join("") +
          `</div>`;
        const note = fa.note
          ? `<div class="qa-line qa-stage-note" title="${escapeHtml(fa.note)}">${escapeHtml(fa.note)}</div>`
          : "";
        return row + note;
      };

      const rows = filtered
        .map((q) => {
          const tag = toTag(q.task_type);
          const isOpen = state.expandedTask === tag;
          const passClass = q.u_pass ? "pass" : "fail";
          const passMark = q.u_pass ? "✓" : "✗";
          return `
            <li class="qa-row ${passClass} ${isOpen ? "open" : ""}" data-task="${tag}">
              <button class="qa-summary">
                <div class="qa-line qa-q">
                  <span class="qa-tag chip-${tag}">${tag}</span>
                  ${phase === "before" ? `<span class="qa-phase-note">(before change or delete)</span>` : ""}
                  <span class="qa-q-text">${escapeHtml(q.question)}</span>
                </div>
                ${stagesHtml(q.failure_analysis)}
                <div class="qa-line qa-a">
                  <span class="qa-label">Agent:</span>
                  <span class="qa-a-text">${escapeHtml(q.agent_answer)}</span>
                </div>
                <div class="qa-line qa-g">
                  <span class="qa-label">Gold:</span>
                  <span class="qa-g-text">${escapeHtml(Array.isArray(q.gold_answer) ? q.gold_answer.join(", ") : q.gold_answer)}</span>
                </div>
              </button>
              ${isOpen ? renderQAExpanded(q, phase, sys) : ""}
            </li>
          `;
        })
        .join("");

      return `
        <div class="qa-pane">
          <div class="qa-head">
            <h4>Probe Q&amp;A trace
              <span class="qa-sub">${phase === "before" ? "before-questions" : "after-questions"} · ${systemLabels[sys].name}</span>
            </h4>
            <div class="qa-ts">evaluation event after session ${probeIdx} · ${escapeHtml(probeTs ?? "")}</div>
          </div>
          <ul class="qa-list">${rows}</ul>
        </div>
      `;
    }

    function renderQAExpanded(q, phase, sys) {
      const reason = q.u_reason
        ? `<div class="qa-reason"><span class="qa-label">Judge:</span> ${escapeHtml(q.u_reason)}</div>`
        : "";
      const tag = (q.task_type ?? "").replace(/[^\w-]+/g, "_");
      const ctxFile = q.retrieved_context_file;
      const ctxBlock = ctxFile
        ? `<div class="qa-ctx" data-system="${sys}" data-phase="${phase}" data-file="${ctxFile}" data-chars="${q.retrieved_context_chars}">
            <button class="qa-ctx-toggle">Show retrieved context (${q.retrieved_context_chars.toLocaleString()} chars)</button>
            <div class="qa-ctx-body"></div>
          </div>`
        : `<div class="qa-ctx-empty">No retrieved context recorded.</div>`;
      return `
        <div class="qa-expanded">
          ${reason}
          ${ctxBlock}
        </div>
      `;
    }

    async function loadRetrievedContext(target, file) {
      target.innerHTML = `<div class="snap-loading">Loading…</div>`;
      try {
        const r = await fetch(`${BASE}sw033/retr/${file}`);
        if (!r.ok) throw new Error("fail");
        const txt = await r.text();
        const lines = txt.split("\n");
        const pre = document.createElement("pre");
        pre.className = "qa-ctx-pre";
        // Incremental render
        let rendered = 0;
        const CHUNK = 300;
        target.innerHTML = "";
        target.appendChild(pre);
        const step = () => {
          const end = Math.min(rendered + CHUNK, lines.length);
          let txt = "";
          for (let i = rendered; i < end; i++) txt += lines[i] + "\n";
          pre.appendChild(document.createTextNode(txt));
          rendered = end;
          if (rendered < lines.length)
            requestIdleCallback
              ? requestIdleCallback(step)
              : setTimeout(step, 16);
        };
        step();
      } catch (e) {
        target.innerHTML = `<div class="snap-error">Failed to load.</div>`;
      }
    }

    function renderDetailPane() {
      const root = document.getElementById("detail-pane");
      if (state.probeMode) {
        root.innerHTML = renderQATrace();
        root.className = "detail-pane detail-probe";
      } else {
        root.innerHTML = `
          <div class="detail-grid">
            <div class="detail-left">${renderSessionPane()}</div>
            <div class="detail-right">${renderSnapshotPane()}</div>
          </div>
        `;
        root.className = "detail-pane detail-normal";
        hookFullSnapshot();
      }
    }

    // ─── Wire events ─────────────────────────────────────────────────
    document.querySelectorAll(".sys-tab").forEach((el) => {
      el.addEventListener("click", () => {
        state.system = el.dataset.system;
        state.expandedTask = null;
        render();
      });
    });

    document.querySelectorAll(".tl-cell").forEach((el) => {
      el.addEventListener("click", () => {
        state.session = +el.dataset.session;
        state.probeMode = null;
        state.expandedTask = null;
        render();
      });
    });

    document.querySelectorAll(".probe-marker").forEach((el) => {
      el.addEventListener("click", () => {
        state.probeMode = el.dataset.probe;
        state.expandedTask = null;
        render();
      });
    });

    document.querySelectorAll(".gcell").forEach((el) => {
      el.addEventListener("click", () => {
        state.system = el.dataset.system;
        state.probeMode = "after";
        state.expandedTask = el.dataset.task;
        render();
        document.getElementById("detail-pane").scrollIntoView({
          behavior: "smooth",
          block: "start",
        });
      });
    });

    // Delegated events for diff toggle and qa rows (re-rendered)
    document.getElementById("detail-pane").addEventListener("click", (e) => {
      const seg = e.target.closest("[data-diff-mode]");
      if (seg) {
        state.diffMode = seg.dataset.diffMode;
        render();
        return;
      }
      const qa = e.target.closest(".qa-summary");
      if (qa) {
        const tag = qa.closest(".qa-row").dataset.task;
        state.expandedTask = state.expandedTask === tag ? null : tag;
        render();
        return;
      }
      const ctxToggle = e.target.closest(".qa-ctx-toggle");
      if (ctxToggle) {
        const wrap = ctxToggle.parentElement;
        const body = wrap.querySelector(".qa-ctx-body");
        if (body.dataset.loaded === "1") {
          body.style.display = body.style.display === "none" ? "" : "none";
        } else {
          loadRetrievedContext(body, wrap.dataset.file);
          body.dataset.loaded = "1";
        }
        return;
      }
    });

    // ─── Render ──────────────────────────────────────────────────────
    function render() {
      syncTabs();
      syncTimeline();
      drawSparkline();
      renderDetailPane();
    }

    render();
  })();
</script>

