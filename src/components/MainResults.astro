---
import data from "../data/main_results.json";

const { task_order, task_long, groups, average, best_per_task_main } = data;

// Best Overall among main (non-subset) systems
const mainRows = groups.flatMap((g) => g.rows.filter((r) => !r.subset));
const bestOverallMain = Math.max(...mainRows.map((r) => r.overall));
const bestOverallSystem = mainRows.find((r) => r.overall === bestOverallMain)?.system;

function fmtRate(v: number) {
  return v.toFixed(2);
}
function fmtCost(v: number | null) {
  if (v === null || v === undefined) return "—";
  if (v === 0) return "$0.00";
  return `$${v.toFixed(2)}`;
}
---

<section class="main-results" aria-labelledby="mr-title">
  <header class="mr-head">
    <h2 id="mr-title">
      <span class="mr-eyebrow">Overall result</span>
      Per-task accuracy across six memory systems
    </h2>
    <p class="mr-meta">
      All systems use <code>gpt-4.1-mini</code> as both internal and answering LLM on 100 episodes
      (filler ≈ 32K tokens). Best per task within the six main systems is in <strong>bold</strong>.
      Cascade, Absence, and Deletion use trivial-pass filtering.
    </p>
  </header>

  <div class="mr-wrap">
    <table class="mr-table">
      <colgroup>
        <col /> {/* System */}
        <col /> <col /> <col /> <col /> <col /> <col /> {/* ER Agg Tr Del Cas Abs */}
        <col class="col-overall" /> {/* Overall */}
        <col /> <col /> {/* Ingest Inference */}
      </colgroup>
      <thead>
        <tr>
          <th scope="col" class="lbl-col" rowspan="2">System</th>
          {task_order.map((t) => (
            <th scope="col" rowspan="2" title={task_long[t]}>{t}</th>
          ))}
          <th scope="col" class="cost-col cost-group" colspan="2">Cost $/ep</th>
        </tr>
        <tr class="sub-head">
          <th class="cost-col">Ingest</th>
          <th class="cost-col">Inference</th>
        </tr>
      </thead>
      <tbody>
        {groups.map((g, gi) => (
          <>
            {g.rows.some((r) => r.subset) && (
              <tr class="avg-row">
                <th scope="row">{average.label}</th>
                {task_order.map((t) => {
                  if (t === "Overall") {
                    return <td class="overall">{fmtRate(average.overall)}</td>;
                  }
                  const danger = t === "Cas" || t === "Abs";
                  return <td class={danger ? "danger" : ""}>{fmtRate(average.rates[t])}</td>;
                })}
                <td class="cost-col">—</td>
                <td class="cost-col">—</td>
              </tr>
            )}
            <tr class="group-row">
              <td colspan={task_order.length + 3}><em>{g.label}</em></td>
            </tr>
            {g.rows.map((row) => (
              <tr class="row">
                <th scope="row" class="sys-name">
                  {row.system}
                  {row.subset && (
                    <span class="sys-llm">{row.internalLLM}{row.subset ? " · 20 ep" : ""}</span>
                  )}
                </th>
                {task_order.map((t) => {
                  if (t === "Overall") {
                    const isBestOverall = !row.subset && row.system === bestOverallSystem;
                    return (
                      <td class="overall">
                        {isBestOverall ? <strong>{fmtRate(row.overall)}</strong> : fmtRate(row.overall)}
                      </td>
                    );
                  }
                  const v = row.rates[t];
                  const isBest = !row.subset && best_per_task_main[t] === row.system;
                  const highlight = row.highlightDeps && (t === "Cas" || t === "Abs");
                  return (
                    <td class={[isBest ? "best" : "", highlight ? "success" : ""].join(" ").trim()}>
                      {isBest ? <strong>{fmtRate(v)}</strong> : fmtRate(v)}
                    </td>
                  );
                })}
                <td class="cost-col">{fmtCost(row.cost.ingest)}</td>
                <td class="cost-col">{fmtCost(row.cost.inference)}</td>
              </tr>
            ))}
          </>
        ))}
      </tbody>
    </table>
  </div>
</section>

<style>
  .main-results {
    margin-top: 64px;
    padding-top: 40px;
    border-top: 1px solid var(--border);
  }
  .mr-head {
    margin-bottom: 18px;
  }
  .mr-eyebrow {
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 12px;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .mr-head h2 {
    margin: 0 0 6px;
    font-size: 22px;
    letter-spacing: -0.01em;
  }
  .mr-meta {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }
  .mr-meta code {
    background: #f3f3ed;
    padding: 1px 5px;
    border-radius: 4px;
  }
  .mr-wrap {
    overflow-x: auto;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 18px;
  }
  .mr-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 13px;
  }
  .mr-table th,
  .mr-table td {
    text-align: center;
    padding: 5px 8px;
    vertical-align: middle;
  }
  .mr-table thead th {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--muted);
    padding-bottom: 8px;
  }
  /* Bottom rule lives only under the row containing tbody, not between thead rows */
  .mr-table thead th[rowspan="2"] {
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }
  .mr-table thead th.cost-group {
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
  }
  .mr-table thead tr.sub-head th {
    border-bottom: 1px solid var(--border);
    padding-bottom: 4px;
    padding-top: 2px;
    font-size: 11px;
    text-transform: none;
  }
  .mr-table tbody .group-row td {
    text-align: left;
    padding: 12px 4px 4px;
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 0;
  }
  .mr-table tbody .row .sys-name {
    text-align: left;
    font-weight: 600;
  }
  .mr-table tbody .row .sys-llm {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--muted);
  }
  .mr-table tbody .row.featured {
    background: #fff8df;
  }
  .mr-table tbody .row.featured .sys-name .star {
    color: #b48a1b;
    margin-right: 4px;
  }
  .mr-table .col-overall {
    background: #f7f7f1;
  }
  .mr-table tbody .overall {
    font-weight: 700;
  }
  /* Highlight Cas/Abs success for Opus closure row */
  .mr-table tbody .row .success {
    color: #1a7c4a;
    font-weight: 700;
    background: #e4f5ea;
  }
  .mr-table tbody .cost-col {
    font-variant-numeric: tabular-nums;
    font-size: 12px;
    color: var(--muted);
  }
  .mr-table tbody .row.featured .cost-col {
    color: var(--fg);
  }
  .mr-table tbody .row .best strong {
    font-weight: 800;
  }
  .mr-table tbody .avg-row {
    border-top: 1px solid var(--border);
    color: var(--muted);
    font-style: italic;
    font-size: 12px;
  }
  .mr-table tbody .avg-row td.danger {
    color: #b94747;
    font-weight: 700;
  }
  .mr-table tbody .avg-row th {
    text-align: left;
    font-weight: 600;
  }
</style>
